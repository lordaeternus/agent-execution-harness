{
  "name": "agent-execution-harness",
  "version": "0.1.0",
  "description": "A transactional execution harness for AI coding agents with evidence-backed reports.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lordaeternus/agent-execution-harness.git"
  },
  "homepage": "https://github.com/lordaeternus/agent-execution-harness#readme",
  "bugs": {
    "url": "https://github.com/lordaeternus/agent-execution-harness/issues"
  },
  "keywords": [
    "ai-agent",
    "coding-agent",
    "agent-harness",
    "evidence",
    "automation",
    "governance"
  ],
  "bin": {
    "agent-harness": "./bin/agent-harness.mjs"
  },
  "files": [
    "dist",
    "bin",
    "schemas",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && vitest run",
    "test:integration": "pnpm build && vitest run tests/integration",
    "benchmark:smoke": "pnpm build && node dist/cli/index.js benchmark --mode smoke",
    "doctor": "pnpm build && node dist/cli/index.js doctor",
    "secret-scan": "node scripts/secret-scan.mjs",
    "pack:dry": "pnpm build && node scripts/pack-check.mjs",
    "audit:release-readiness": "node scripts/audit-release-readiness.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
