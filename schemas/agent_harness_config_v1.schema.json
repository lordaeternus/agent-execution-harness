{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_harness_config_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_dir", "product_paths", "required_scripts", "doctor_profile", "command_policy"],
  "properties": {
    "schema_version": { "const": "agent_harness_config_v1" },
    "artifact_dir": { "type": "string", "minLength": 1 },
    "product_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "required_scripts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "doctor_profile": { "enum": ["generic", "stetix", "strict", "ci"] },
    "command_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
