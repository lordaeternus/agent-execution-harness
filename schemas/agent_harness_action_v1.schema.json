{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_harness_action_v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "type"],
  "properties": {
    "schema_version": { "const": "agent_harness_action_v1" },
    "type": {
      "enum": ["read_context", "declare_files", "edit_file_ready", "run_gate", "record_evidence", "verify_claims", "final_report", "halt_for_risk"]
    },
    "summary": { "type": "string" },
    "task_id": { "type": "string" },
    "files": { "type": "array", "items": { "type": "string" } },
    "command": { "type": "string" },
    "evidence": {
      "type": "object",
      "properties": {
        "evidence_type": { "type": "string" },
        "evidence_types": { "type": "array", "items": { "type": "string" } },
        "output_ref": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
      }
    }
  }
}
