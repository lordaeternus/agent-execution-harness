{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_harness_plan_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "risk_level", "rollback_expectation", "gates", "tasks"],
  "properties": {
    "schema_version": { "const": "agent_harness_plan_v1" },
    "plan_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$", "minLength": 1 },
    "risk_level": { "enum": ["L1", "L2", "L3"] },
    "rollback_expectation": { "type": "string", "minLength": 1 },
    "gates": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "acceptance_criteria"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$", "minLength": 1 },
          "acceptance_criteria": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
