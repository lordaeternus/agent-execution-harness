{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_harness_lesson_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "lesson_id", "surface", "kind", "summary", "files", "evidence_refs", "status", "confidence", "created_at", "updated_at", "expires_at"],
  "properties": {
    "schema_version": { "const": "agent_harness_lesson_v1" },
    "lesson_id": { "type": "string", "minLength": 1, "pattern": "^[a-zA-Z0-9._-]+$" },
    "surface": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["failure_pattern", "fix_pattern", "architecture_fact", "verification_rule", "rollback_note"] },
    "summary": { "type": "string", "minLength": 40 },
    "files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "status": { "enum": ["candidate", "validated", "promoted", "stale", "rejected", "retired"] },
    "confidence": { "enum": ["low", "medium", "high"] },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "minLength": 1 },
    "failure_signature": { "type": "string" },
    "fix_pattern": { "type": "string" },
    "file_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    },
    "reason": { "type": "string" }
  }
}
